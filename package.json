{
  "name": "client-md-viewer",
  "version": "1.2.2",
  "description": "Offline Markdown report viewer and editor for Windows",
  "main": "src/main.js",
  "author": "Klimat Shop",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "dist": "electron-builder --win",
    "test:pdf": "electron test/smoke-pdf.js"
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ru.klimatshop.markdownviewer",
    "productName": "MD Reports",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "node_modules/**/*",
      "package.json"
    ],
    "portable": {
      "artifactName": "MD-Reports-Portable-${version}.exe"
    },
    "nsis": {
      "artifactName": "MD-Reports-Setup-${version}.exe",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MD Reports",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": "txt",
        "name": "Text Document",
        "description": "Text document",
        "role": "Editor"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
