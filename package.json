{
  "name": "client-md-viewer",
  "version": "1.3.1",
  "description": "Offline Markdown report viewer and editor for Windows",
  "main": "src/main.js",
  "author": "Klimat Shop",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "dist": "electron-builder --win --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux AppImage deb --publish never",
    "build:mac": "electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "test:pdf": "electron test/smoke-pdf.js"
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ru.klimatshop.markdownviewer",
    "productName": "MD Reports",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "node_modules/**/*",
      "package.json"
    ],
    "portable": {
      "artifactName": "MD-Reports-Portable-${version}.exe"
    },
    "nsis": {
      "artifactName": "MD-Reports-Setup-${version}.exe",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MD Reports",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": "txt",
        "name": "Text Document",
        "description": "Text document",
        "role": "Editor"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office",
      "maintainer": "Klimat Shop",
      "artifactName": "MD-Reports-${version}-Linux-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "MD-Reports-${version}-macOS-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
